[Desktop Entry]
Type=Application
Name=Diction
Exec=diction
Icon=io.github.fastrizwaan.diction
Terminal=false
StartupNotify=true
DBusActivatable=true
X-GNOME-SingleWindow=true
X-Flatpak-RenameFrom=io.github.fastrizwaan.diction.desktop;
Categories=Utility;Education;Dictionary;

# Generic Name
GenericName=Dictionary
GenericName[ru]=Словарь
GenericName[zh_CN]=词典
GenericName[es]=Diccionario
GenericName[nl]=Woordenboek
GenericName[fr]=Dictionnaire
GenericName[de]=Wörterbuch
GenericName[hi]=शब्दकोश
GenericName[ar]=قاموس
GenericName[pt]=Dicionário
GenericName[bn]=অভিধান
GenericName[ja]=辞書

# Comment
Comment=A high-performance, multi-format offline dictionary
Comment[ru]=Высокопроизводительный офлайн-словарь с поддержкой множества форматов
Comment[zh_CN]=一款高性能的离线词典，支持多种词典格式
Comment[es]=Un diccionario sin conexión de alto rendimiento con soporte para múltiples formatos
Comment[nl]=Een krachtige offline woordenboekapp met ondersteuning voor meerdere formaten
Comment[fr]=Un dictionnaire hors ligne performant prenant en charge plusieurs formats
Comment[de]=Ein leistungsstarkes Offline-Wörterbuch mit Unterstützung für mehrere Formate
Comment[hi]=एक उच्च-प्रदर्शन ऑफलाइन शब्दकोश जो कई प्रारूपों का समर्थन करता है
Comment[ar]=قاموس غير متصل عالي الأداء يدعم تنسيقات متعددة
Comment[pt]=Um dicionário offline de alto desempenho com suporte a vários formatos
Comment[bn]=একটি উচ্চ-দক্ষ অফলাইন অভিধান যা একাধিক ফরম্যাট সমর্থন করে
Comment[ja]=複数の辞書形式に対応した高性能なオフライン辞書

